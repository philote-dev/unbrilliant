{
  "name": "unbrilliant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "dev:e2e": "vite --port 5273 --strictPort",
    "gallery": "vite --mode frozen --port 5174 --strictPort --open /gallery.html",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:emulator": "PATH=\"$(/usr/libexec/java_home -v 21+ 2>/dev/null)/bin:$PATH\" npx -y firebase-tools@latest emulators:exec --only auth,firestore --project demo-willow \"vitest run --config vitest.emulator.config.ts\"",
    "e2e": "PATH=\"$(/usr/libexec/java_home -v 21+ 2>/dev/null)/bin:$PATH\" npx -y firebase-tools@latest emulators:exec --only auth,firestore --project demo-willow \"playwright test\""
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.41.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }

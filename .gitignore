# Critical
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test & emulator artifacts
test-results
playwright-report
.firebase

# Agent / tool config & artifacts (kept local per project decision)
.cursor/
.agents/
.playwright-mcp/
.superpowers/
CLAUDE.md
skills-lock.json

# Local Firebase project binding (use .firebaserc.example as the template)
.firebaserc

# Docs: outward-facing docs and planning docs are tracked; other internal working docs stay local
docs/*
!docs/architecture.md
!docs/plans/

# Dev gallery: track only the gallery entry (gallery.html + src/dev/gallery.tsx).
# Personal dev labs under src/dev/ stay local. The gallery is served by
# `npm run gallery` and is not a production build input (only index.html is built).
src/dev/*
!src/dev/gallery.tsx

# Cloud Functions build output
functions/lib

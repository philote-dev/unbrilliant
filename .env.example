# Firebase WEB config — only needed for PRODUCTION builds.
# Vite inlines VITE_* values into the bundle at build time. These are NOT secrets:
# Firebase web config is public by design; access is controlled by Firestore
# security rules + Auth, not by hiding these values.
#
# Dev and tests ALWAYS use the local emulators (a `demo-` project) and ignore
# these, so you can `npm run dev` / run tests without filling them in. Populate
# them (from Firebase console → Project settings → General → Your apps) only when
# you need a production build or deploy, then copy this file to `.env`.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
